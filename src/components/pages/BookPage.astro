---
import Layout from '../../layouts/Layout.astro';
import { type Lang } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);

const seasonShort = (t('book.season.short') as string).split('\n');
const seasonLong = (t('book.season.long') as string).split('\n');
---

<Layout lang={lang} title={t('book.meta.title')} description={t('book.meta.description')}>
  <section class="page-hero">
    <img src="https://www.villa-etxola.com/wp-content/uploads/2021/07/Villa-Etxola-contact-us-carousel-14.jpg"
         alt="" class="absolute inset-0 w-full h-full object-cover" fetchpriority="high" />
    <div class="hero-overlay"></div>
    <h1 class="hero-title">{t('book.hero.title')}</h1>
  </section>

  <section class="py-16 px-4 bg-white dark:bg-gray-950">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="section-title mb-6">{t('book.intro.title')}</h2>
      <div class="w-16 h-0.5 bg-green-800 dark:bg-green-500 mx-auto mb-8"></div>
      <p class="section-subtitle">{t('book.intro.text')}</p>
    </div>
  </section>

  <section class="pb-20 px-4 bg-white dark:bg-gray-950">
    <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-12 items-start">
      <div>
        <address class="not-italic mb-8">
          <h3 class="text-sm font-semibold uppercase tracking-widest text-gray-800 dark:text-gray-100 mb-4">{t('book.contact.name')}</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">40 boulevard des Mimosas</p>
          <p class="text-sm text-gray-600 dark:text-gray-400">33970 Lège-Cap-Ferret</p>
          <p class="text-sm text-gray-600 dark:text-gray-400">France</p>
          <p class="text-sm text-gray-600 dark:text-gray-400 mt-3">
            <a href="tel:+33750021103" class="hover:text-green-800 dark:hover:text-green-400 transition-colors font-medium">
              +33 (0) 7 50 02 11 03
            </a>
          </p>
        </address>

        <img src="https://www.villa-etxola.com/wp-content/uploads/2021/07/Villa-Etxola-05.jpg"
             alt="" class="w-full rounded object-cover h-64 md:h-80" loading="lazy" />

        <div class="mt-8 p-6 border border-green-200 dark:border-green-800/50 bg-green-50 dark:bg-green-950/30 rounded">
          <h4 class="text-sm font-semibold uppercase tracking-widest text-green-800 dark:text-green-400 mb-3">{t('book.season.title')}</h4>
          <p class="text-sm text-gray-700 dark:text-gray-300 mb-3">
            <strong>{seasonShort[0]}</strong><br />
            {seasonShort[1]}
          </p>
          <p class="text-sm text-gray-700 dark:text-gray-300 mb-3">
            <strong>{seasonLong[0]}</strong><br />
            {seasonLong[1]}
          </p>
          <p class="text-xs text-gray-500 dark:text-gray-500">{t('book.season.note')}</p>
        </div>
      </div>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-widest text-gray-800 dark:text-gray-100 mb-8">{t('book.contact.send')}</h3>
        <form id="booking-form" class="space-y-5" novalidate>
          <input type="text" name="name" placeholder={t('book.form.name')} required
            class="w-full px-4 py-3 border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-100 text-sm rounded focus:outline-none focus:border-green-700 dark:focus:border-green-500 transition-colors placeholder-gray-400 dark:placeholder-gray-500" />
          <input type="email" name="email" placeholder={t('book.form.email')} required
            class="w-full px-4 py-3 border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-100 text-sm rounded focus:outline-none focus:border-green-700 dark:focus:border-green-500 transition-colors placeholder-gray-400 dark:placeholder-gray-500" />
          <input type="tel" name="phone" placeholder={t('book.form.phone')}
            class="w-full px-4 py-3 border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-100 text-sm rounded focus:outline-none focus:border-green-700 dark:focus:border-green-500 transition-colors placeholder-gray-400 dark:placeholder-gray-500" />
          <div class="grid grid-cols-2 gap-4">
            <select name="adults" class="w-full px-4 py-3 border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-600 dark:text-gray-400 text-sm rounded focus:outline-none focus:border-green-700 dark:focus:border-green-500 transition-colors">
              <option value="">{t('book.form.adults')}</option>
              {Array.from({ length: 14 }, (_, i) => i + 1).map(n => <option value={n}>{n}</option>)}
            </select>
            <select name="children" class="w-full px-4 py-3 border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-600 dark:text-gray-400 text-sm rounded focus:outline-none focus:border-green-700 dark:focus:border-green-500 transition-colors">
              <option value="">{t('book.form.children')}</option>
              {Array.from({ length: 8 }, (_, i) => i + 1).map(n => <option value={n}>{n}</option>)}
            </select>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <select name="flexible" class="w-full px-4 py-3 border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-600 dark:text-gray-400 text-sm rounded focus:outline-none focus:border-green-700 dark:focus:border-green-500 transition-colors">
              <option value="">{t('book.form.flexible')}</option>
              <option value="yes">{t('book.form.yes')}</option>
              <option value="no">{t('book.form.no')}</option>
            </select>
            <select name="firsttime" class="w-full px-4 py-3 border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-600 dark:text-gray-400 text-sm rounded focus:outline-none focus:border-green-700 dark:focus:border-green-500 transition-colors">
              <option value="">{t('book.form.firsttime')}</option>
              <option value="yes">{t('book.form.yes')}</option>
              <option value="no">{t('book.form.no')}</option>
            </select>
          </div>
          <textarea name="message" rows="5" placeholder={t('book.form.message')}
            class="w-full px-4 py-3 border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-100 text-sm rounded focus:outline-none focus:border-green-700 dark:focus:border-green-500 transition-colors placeholder-gray-400 dark:placeholder-gray-500 resize-none"></textarea>
          <button type="submit"
            class="w-full py-4 border border-gray-800 dark:border-white text-gray-800 dark:text-white text-xs uppercase tracking-widest font-semibold hover:bg-gray-800 dark:hover:bg-white hover:text-white dark:hover:text-gray-900 transition-all duration-200">
            {t('book.form.submit')}
          </button>
          <div id="form-success" class="hidden text-center py-4 text-green-700 dark:text-green-400 text-sm">{t('book.form.success')}</div>
          <div id="form-error" class="hidden text-center py-4 text-red-600 dark:text-red-400 text-sm">{t('book.form.error')}</div>
        </form>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('booking-form') as HTMLFormElement | null;
  const successMsg = document.getElementById('form-success');
  const errorMsg = document.getElementById('form-error');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const name = (form.querySelector('[name="name"]') as HTMLInputElement).value.trim();
    const email = (form.querySelector('[name="email"]') as HTMLInputElement).value.trim();

    if (!name || !email) {
      errorMsg?.classList.remove('hidden');
      successMsg?.classList.add('hidden');
      return;
    }
    successMsg?.classList.remove('hidden');
    errorMsg?.classList.add('hidden');
    form.reset();
  });
</script>
