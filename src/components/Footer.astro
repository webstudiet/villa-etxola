---
import { routes, type Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);

const navLinks = [
  { href: routes[lang].home, label: t('nav.villa') },
  { href: routes[lang].facilities, label: t('nav.facilities') },
  { href: routes[lang].services, label: t('nav.services') },
  { href: routes[lang].capferret, label: t('nav.capferret') },
  { href: routes[lang].gallery, label: t('nav.gallery') },
  { href: routes[lang].book, label: t('nav.book') },
];
---

<footer class="bg-white dark:bg-gray-900 border-t border-gray-200 dark:border-gray-800">
  <div class="h-1 bg-gradient-to-r from-stone-300 via-green-800 to-stone-300"></div>

  <div class="max-w-7xl mx-auto px-4 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <div class="flex flex-col items-start gap-4">
        <a href={routes[lang].home} aria-label="Etxola">
          <img src="https://www.villa-etxola.com/wp-content/uploads/2021/03/etxola-logo.png"
               alt="Etxola" width="160" height="80" class="h-20 w-auto" />
        </a>
        <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">
          {t('footer.summary')}
        </p>
      </div>

      <div>
        <h3 class="text-xs uppercase tracking-widest font-semibold text-gray-400 dark:text-gray-500 mb-6">{t('footer.navigation')}</h3>
        <nav class="flex flex-col gap-3" aria-label="Footer">
          {navLinks.map(link => (
            <a href={link.href}
               class="text-sm text-gray-700 dark:text-gray-300 hover:text-green-800 dark:hover:text-green-400 transition-colors uppercase tracking-wider">
              {link.label}
            </a>
          ))}
        </nav>
      </div>

      <div>
        <h3 class="text-xs uppercase tracking-widest font-semibold text-gray-400 dark:text-gray-500 mb-6">{t('footer.contact')}</h3>
        <address class="not-italic text-sm text-gray-600 dark:text-gray-400 leading-relaxed mb-6">
          <p>40, boulevard des Mimosas</p>
          <p>33970 Lège-Cap-Ferret</p>
          <p>France</p>
          <p class="mt-2">
            <a href="tel:+33750021103" class="hover:text-green-800 dark:hover:text-green-400 transition-colors">
              +33 (0) 7 50 02 11 03
            </a>
          </p>
        </address>
        <a href={routes[lang].book}
           class="inline-block px-8 py-3 border border-gray-800 dark:border-white text-gray-800 dark:text-white text-xs uppercase tracking-widest font-semibold hover:bg-gray-800 dark:hover:bg-white hover:text-white dark:hover:text-gray-900 transition-all duration-200">
          {t('nav.book')}
        </a>
        <div class="flex items-center gap-4 mt-6">
          <a href="https://www.instagram.com/villa.etxola33/" target="_blank" rel="noopener"
             class="text-gray-500 dark:text-gray-400 hover:text-green-800 dark:hover:text-green-400 transition-colors"
             aria-label="Instagram">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="border-t border-gray-200 dark:border-gray-800">
    <div class="max-w-7xl mx-auto px-4 py-4 flex flex-col sm:flex-row justify-between items-center gap-2 text-xs text-gray-500 dark:text-gray-500">
      <p>&copy; {new Date().getFullYear()} Villa Etxola. {t('footer.rights')}</p>
      <div class="flex gap-4">
        <span>{t('footer.terms')}</span>
        <span>{t('footer.privacy')}</span>
      </div>
    </div>
  </div>
</footer>
