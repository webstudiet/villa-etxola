---
import { routes, type Lang } from '../i18n/ui';
import { useTranslations, getRouteKeyForPath, getAlternateLang } from '../i18n/utils';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);

const navLinks = [
  { href: routes[lang].home, label: t('nav.villa') },
  { href: routes[lang].facilities, label: t('nav.facilities') },
  { href: routes[lang].services, label: t('nav.services') },
  { href: routes[lang].capferret, label: t('nav.capferret') },
  { href: routes[lang].gallery, label: t('nav.gallery') },
];

const currentPath = Astro.url.pathname;
const routeKey = getRouteKeyForPath(currentPath);
const altLang = getAlternateLang(lang);
const altHref = routeKey ? routes[altLang][routeKey] : routes[altLang].home;
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" data-transparent="true">
  <!-- Top bar -->
  <div id="top-bar" class="bg-black/60 text-white text-xs py-2 transition-all duration-300">
    <div class="max-w-7xl mx-auto px-4 flex justify-between items-center">
      <a href="tel:+33750021103" class="tracking-wider hover:text-white">+33 (0) 7 50 02 11 03</a>
      <div class="flex items-center gap-4">
        <a href={altHref} class="uppercase tracking-widest hover:text-gray-300 transition-colors" aria-label={t('lang.switch')}>
          {altLang.toUpperCase()}
        </a>
        <span class="text-white/60">|</span>
        <a href="https://www.instagram.com/villa.etxola33/" target="_blank" rel="noopener" class="hover:text-gray-300 transition-colors" aria-label="Instagram">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
        <button onclick="window.toggleDarkMode()" aria-label="Toggle dark mode" class="p-1 rounded hover:bg-white/10 transition-colors">
          <svg class="w-4 h-4 dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
          <svg class="w-4 h-4 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Main nav -->
  <nav class="bg-black/40 backdrop-blur-sm transition-all duration-300" id="main-nav" aria-label="Primary">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex items-center justify-between py-4">
        <a href={routes[lang].home} class="flex-shrink-0">
          <img src="/images/etxola-logo-white.png"
               alt="Etxola" width="160" height="64" class="h-12 md:h-16 w-auto transition-all duration-300" id="nav-logo" />
        </a>

        <div class="hidden lg:flex items-center gap-1">
          {navLinks.map(link => (
            <a href={link.href}
               class={`px-4 py-2 text-xs uppercase tracking-widest font-medium transition-colors duration-200
                 ${currentPath === link.href || (link.href !== routes[lang].home && currentPath.startsWith(link.href))
                   ? 'text-white border-b border-white'
                   : 'text-white/80 hover:text-white'}`}>
              {link.label}
            </a>
          ))}
          <a href={routes[lang].book}
             class="ml-4 px-6 py-2 border border-white text-white text-xs uppercase tracking-widest font-semibold hover:bg-white hover:text-gray-900 transition-all duration-200">
            {t('nav.book')}
          </a>
        </div>

        <button id="mobile-menu-btn" class="lg:hidden text-white p-2" aria-label={t('nav.menu.open')} aria-expanded="false" aria-controls="mobile-menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <div id="mobile-menu" class="hidden lg:hidden bg-black/90 backdrop-blur-md">
      <div class="max-w-7xl mx-auto px-4 py-4 flex flex-col gap-2">
        {navLinks.map(link => (
          <a href={link.href}
             class="text-white/80 hover:text-white py-3 border-b border-white/10 text-sm uppercase tracking-widest transition-colors">
            {link.label}
          </a>
        ))}
        <a href={routes[lang].book}
           class="mt-4 text-center py-3 border border-white text-white text-sm uppercase tracking-widest hover:bg-white hover:text-gray-900 transition-all">
          {t('nav.book')}
        </a>
        <a href={altHref} class="text-center py-3 text-white/70 hover:text-white text-xs uppercase tracking-widest transition-colors">
          {t('lang.switch')}
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  const mainNav = document.getElementById('main-nav');
  const topBar = document.getElementById('top-bar');
  const navLogo = document.getElementById('nav-logo') as HTMLImageElement | null;
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 80) {
      mainNav?.classList.remove('bg-black/40');
      mainNav?.classList.add('bg-white', 'dark:bg-gray-950', 'shadow-lg');
      topBar?.classList.add('hidden');
      if (navLogo) {
        navLogo.src = '/images/etxola-logo.png';
        navLogo.classList.add('h-10');
        navLogo.classList.remove('h-12', 'md:h-16');
      }
      document.querySelectorAll('#main-nav a').forEach(a => {
        a.classList.remove('text-white/80', 'text-white');
        a.classList.add('text-gray-800', 'dark:text-white');
      });
    } else {
      mainNav?.classList.add('bg-black/40');
      mainNav?.classList.remove('bg-white', 'dark:bg-gray-950', 'shadow-lg');
      topBar?.classList.remove('hidden');
      if (navLogo) {
        navLogo.src = '/images/etxola-logo-white.png';
        navLogo.classList.remove('h-10');
        navLogo.classList.add('h-12', 'md:h-16');
      }
      document.querySelectorAll('#main-nav a').forEach(a => {
        a.classList.add('text-white/80');
        a.classList.remove('text-gray-800', 'dark:text-white');
      });
    }
  });

  mobileMenuBtn?.addEventListener('click', () => {
    const open = mobileMenu?.classList.toggle('hidden') === false;
    mobileMenuBtn.setAttribute('aria-expanded', String(open));
  });
</script>
